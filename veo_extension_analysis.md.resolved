## IV. ⚙️ Service Worker — Bộ Não Điều Phối

`background/service-worker.js` — không có DOM, chạy như một "server nhỏ" trong Chrome.

```javascript
// === KHỞI TẠO ===
chrome.runtime.onInstalled.addListener(() => {
  // Mở Side Panel khi click icon extension
  chrome.sidePanel.setPanelBehavior({ openPanelOnActionClick: true });
});

// === QUEUE ENGINE ===
class QueueManager {
  constructor() {
    this.queue = [];       // Danh sách jobs chờ
    this.running = [];     // Jobs đang chạy (concurrency)
    this.maxConcurrent = 2; // Chạy tối đa 2 jobs song song
  }

  async add(promptJob) {
    this.queue.push(promptJob);
    await this.saveToStorage(); // Lưu persistent
    this.processNext();         // Bắt đầu xử lý
  }

  async processNext() {
    if (this.running.length >= this.maxConcurrent) return;
    if (this.queue.length === 0) return;

    const job = this.queue.shift();
    this.running.push(job);

    try {
      await this.executeJob(job);
    } finally {
      this.running = this.running.filter(j => j.id !== job.id);
      this.notifyPanel('job_completed', job);
      this.processNext(); // Chạy job tiếp theo
    }
  }

  async executeJob(job) {
    // Tìm tab Google Flow đang mở
    const [tab] = await chrome.tabs.query({
      url: 'https://labs.google.com/fx/tools/flow/*'
    });

    // Gửi lệnh xuống Content Script để thực hiện
    const result = await chrome.tabs.sendMessage(tab.id, {
      action: 'CREATE_AND_RUN_PROMPT',
      payload: {
        prompt: job.prompt,
        model: job.model,       // "veo-3.1-fast" | "veo-2-quality"
        aspectRatio: job.ratio, // "16:9" | "9:16" | "1:1"
        duration: job.duration, // 5s | 8s
        referenceImage: job.lastImage // last frame chaining!
      }
    });

    // Khi video xong → tự động download
    if (result.videoUrl) {
      await this.downloadVideo(result.videoUrl, job);
    }
  }

  async downloadVideo(url, job) {
    await chrome.downloads.download({
      url: url,
      filename: `flow/${job.projectName}/${job.index}_${job.prompt.slice(0,30)}.mp4`,
      conflictAction: 'uniquify'
    });
  }

  // Broadcast trạng thái hàng đợi lên Side Panel
  notifyPanel(event, data) {
    chrome.runtime.sendMessage({ event, data });
  }

  // Lưu queue vào chrome.storage để survive browser restart
  async saveToStorage() {
    await chrome.storage.local.set({ queue: this.queue });
  }
}

const queueManager = new QueueManager();

// Lắng nghe lệnh từ Side Panel UI
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  if (msg.action === 'ADD_JOBS') {
    msg.jobs.forEach(job => queueManager.add(job));
    sendResponse({ status: 'queued' });
  }
  if (msg.action === 'GET_STATUS') {
    sendResponse({ queue: queueManager.queue, running: queueManager.running });
  }
  return true; // async response
});
```

