## V. 💉 Content Script — Tay Chân Thao Tác DOM

`content-scripts/flow-automator.js` — đây là phần **phức tạp và quan trọng nhất**.

```javascript
// Chạy trong context của trang labs.google.com/fx/tools/flow

// Helper: chờ element xuất hiện (Google Flow render async)
function waitForElement(selector, timeout = 10000) {
  return new Promise((resolve, reject) => {
    const observer = new MutationObserver(() => {
      const el = document.querySelector(selector);
      if (el) { observer.disconnect(); resolve(el); }
    });
    observer.observe(document.body, { childList: true, subtree: true });
    setTimeout(() => { observer.disconnect(); reject('Timeout: ' + selector); }, timeout);
  });
}

// Helper: simulate typing vào React input (React dùng synthetic events)
function setReactInputValue(input, value) {
  const nativeInputValueSetter = Object.getOwnPropertyDescriptor(
    window.HTMLTextAreaElement.prototype, 'value'
  ).set;
  nativeInputValueSetter.call(input, value);
  input.dispatchEvent(new Event('input', { bubbles: true }));
  input.dispatchEvent(new Event('change', { bubbles: true }));
}

// Nhận lệnh từ Service Worker
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  if (msg.action === 'CREATE_AND_RUN_PROMPT') {
    runAutomation(msg.payload).then(sendResponse);
    return true; // keep channel open for async
  }
});

async function runAutomation(config) {
  try {
    // BƯỚC 1: Click nút "New Project" hoặc tạo project mới
    const newBtn = await waitForElement('[data-action="new-flow"]');
    newBtn.click();
    await sleep(1500);

    // BƯỚC 2: Chọn loại generation (Text to Video, Image to Video...)
    await selectGenerationMode(config.mode);

    // BƯỚC 3: Nếu có reference image → upload
    if (config.referenceImage) {
      await uploadReferenceImage(config.referenceImage);
    }

    // BƯỚC 4: Điền prompt vào textarea
    const promptArea = await waitForElement('textarea[placeholder*="prompt"]');
    setReactInputValue(promptArea, config.prompt);
    await sleep(500);

    // BƯỚC 5: Chọn Model (Veo 3.1 Fast/Quality, Veo 2...)
    await selectModel(config.model);

    // BƯỚC 6: Chọn Aspect Ratio
    await selectAspectRatio(config.aspectRatio);

    // BƯỚC 7: Chọn Duration
    await selectDuration(config.duration);

    // BƯỚC 8: Click Generate!
    const generateBtn = await waitForElement('button[aria-label*="Generate"]');
    generateBtn.click();

    // BƯỚC 9: Chờ video/ảnh hoàn thành
    const resultUrl = await waitForGenerationComplete();

    // BƯỚC 10: Lấy URL video/ảnh cuối để chain
    const lastFrameUrl = await extractLastFrame(resultUrl);

    return { success: true, videoUrl: resultUrl, lastImage: lastFrameUrl };

  } catch (err) {
    return { success: false, error: err.message };
  }
}

async function waitForGenerationComplete() {
  return new Promise((resolve) => {
    // Poll mỗi 2 giây để check trạng thái
    const interval = setInterval(() => {
      // Tìm progress bar đã đầy hoặc video element xuất hiện
      const video = document.querySelector('video[src*="blob:"]');
      const progress = document.querySelector('[aria-valuenow="100"]');

      if (video || progress) {
        clearInterval(interval);
        resolve(video?.src || extractDownloadUrl());
      }
    }, 2000);
  });
}

function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}
```

