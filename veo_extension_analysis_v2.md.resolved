## V. 💉 CONTENT SCRIPT — DOM Automation Chuyên Sâu

> [!CAUTION]
> Đây là phần **KHÓ NHẤT VÀ PHỨC TẠP NHẤT** của extension. Google Flow là React SPA — mọi DOM manipulation đều phải "hack" qua React.

```javascript
// ========================================================
// content-scripts/flow-automator.js
// Chạy TRONG context trang labs.google.com/fx/tools/flow
// Có access DOM của Google Flow nhưng KHÔNG access window JS của page
// (chạy trong Isolated World)
// ========================================================

// ══════════════════════════════════════════════
// PHẦN 1: UTILITIES — Các hàm helper cốt lõi
// ══════════════════════════════════════════════

/**
 * Chờ element xuất hiện trong DOM (cho React async rendering)
 * Google Flow render async — element không có ngay khi page load
 * Dùng MutationObserver thay vì setTimeout (đáng tin cậy hơn)
 */
function waitForElement(selector, timeout = 15000) {
  return new Promise((resolve, reject) => {
    // Check ngay — có thể element đã tồn tại
    const existing = document.querySelector(selector);
    if (existing) return resolve(existing);

    const observer = new MutationObserver((mutations, obs) => {
      const el = document.querySelector(selector);
      if (el) {
        obs.disconnect();
        resolve(el);
      }
    });

    observer.observe(document.body, {
      childList: true,   // Phát hiện thêm/xóa child nodes
      subtree: true,     // Theo dõi TOÀN BỘ DOM tree, không chỉ children trực tiếp
      attributes: true   // Phát hiện thay đổi attributes (class, style...)
    });

    setTimeout(() => {
      observer.disconnect();
      reject(new Error(`Element "${selector}" not found after ${timeout}ms`));
    }, timeout);
  });
}

/**
 * Chờ element BIẾN MẤT (ví dụ: loading spinner)
 */
function waitForElementGone(selector, timeout = 120000) {
  return new Promise((resolve, reject) => {
    const check = () => {
      if (!document.querySelector(selector)) return resolve();
      requestAnimationFrame(check);
    };
    check();
    setTimeout(() => reject(new Error('Element still exists: ' + selector)), timeout);
  });
}

/**
 * ★★★ TRICK QUAN TRỌNG NHẤT ★★★
 * Set giá trị vào React-controlled input
 *
 * Tại sao input.value = "text" KHÔNG HOẠT ĐỘNG?
 * → React dùng "controlled components" — nó override native setter
 * → React chỉ update state khi nhận được synthetic event
 * → Ta phải gọi NATIVE setter rồi dispatch event
 */
function setReactInputValue(element, value) {
  // Xác định prototype dựa trên loại element
  const proto = element instanceof HTMLTextAreaElement
    ? HTMLTextAreaElement.prototype
    : HTMLInputElement.prototype;

  // Lấy native setter (bỏ qua React override)
  const nativeSetter = Object.getOwnPropertyDescriptor(proto, 'value').set;

  // Set giá trị qua native setter
  nativeSetter.call(element, value);

  // Dispatch events mà React lắng nghe
  element.dispatchEvent(new Event('input', { bubbles: true, cancelable: true }));
  element.dispatchEvent(new Event('change', { bubbles: true, cancelable: true }));

  // Một số React versions cần thêm KeyboardEvent
  element.dispatchEvent(new KeyboardEvent('keydown', { bubbles: true }));
  element.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true }));
}

/**
 * Click element theo cách React nhận ra
 * Đôi khi element.click() không đủ cho React
 */
function reactClick(element) {
  // Dispatch full sequence: mousedown → mouseup → click
  element.dispatchEvent(new MouseEvent('mousedown', { bubbles: true }));
  element.dispatchEvent(new MouseEvent('mouseup', { bubbles: true }));
  element.dispatchEvent(new MouseEvent('click', { bubbles: true }));
}

function sleep(ms) {
  return new Promise(r => setTimeout(r, ms));
}

// ══════════════════════════════════════════════
// PHẦN 2: SELECTOR STRATEGY — Tìm element đúng
// ══════════════════════════════════════════════

/**
 * Google Flow thường xuyên thay đổi class names (hashed CSS modules)
 * VÍ DỤ: class="css-1a2b3c" → thay đổi mỗi lần deploy
 *
 * CHIẾN LƯỢC: Dùng multiple fallback selectors
 * Ưu tiên: aria-label > data-* > role > text content > class
 */
const SELECTORS = {
  // Nút tạo project mới
  newProject: [
    '[aria-label*="New"]',
    '[data-action="new-flow"]',
    'button:has(svg[data-icon="plus"])',
    // Fallback: tìm bằng text content
    () => [...document.querySelectorAll('button')]
      .find(b => b.textContent.includes('New'))
  ],

  // Textarea nhập prompt
  promptInput: [
    'textarea[placeholder*="prompt"]',
    'textarea[placeholder*="Describe"]',
    'textarea[aria-label*="prompt"]',
    '.prompt-input textarea',
    'textarea'  // Last resort
  ],

  // Nút Generate
  generateButton: [
    'button[aria-label*="Generate"]',
    'button[aria-label*="Create"]',
    '[data-action="generate"]',
    () => [...document.querySelectorAll('button')]
      .find(b => b.textContent.match(/Generate|Create|Submit/i))
  ],

  // Model selector dropdown
  modelSelector: [
    '[aria-label*="model"]',
    '[data-testid="model-selector"]',
    'select[name*="model"]'
  ],

  // Aspect ratio buttons
  aspectRatio: {
    '16:9': '[aria-label*="16:9"], [data-ratio="16:9"]',
    '9:16': '[aria-label*="9:16"], [data-ratio="9:16"]',
    '1:1':  '[aria-label*="1:1"], [data-ratio="1:1"]'
  },

  // Progress/completion indicators
  progressBar: '[role="progressbar"], [aria-valuenow]',
  videoElement: 'video[src], video source[src]',
  completionBadge: '[data-status="complete"], .generation-complete',
  errorIndicator: '[data-status="error"], .generation-error'
};

/**
 * Tìm element từ danh sách selectors (fallback chain)
 */
async function findElement(selectorList) {
  if (!Array.isArray(selectorList)) selectorList = [selectorList];

  for (const sel of selectorList) {
    try {
      if (typeof sel === 'function') {
        const el = sel();
        if (el) return el;
      } else {
        const el = await waitForElement(sel, 3000);
        if (el) return el;
      }
    } catch { /* try next */ }
  }
  throw new Error('No element found for selectors: ' + JSON.stringify(selectorList));
}

// ══════════════════════════════════════════════
// PHẦN 3: MAIN AUTOMATION FLOW
// ══════════════════════════════════════════════

chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  if (msg.action === 'EXECUTE_AUTOMATION') {
    executeAutomation(msg.payload)
      .then(result => sendResponse(result))
      .catch(err => sendResponse({ success: false, error: err.message }));
    return true; // Keep message channel open for async
  }
});

async function executeAutomation(job) {
  // ————— STEP 1: Tạo Project mới —————
  const newBtn = await findElement(SELECTORS.newProject);
  reactClick(newBtn);
  await sleep(2000); // Chờ animation transition

  // ————— STEP 2: Chọn Generation Mode —————
  await selectMode(job.mode);
  await sleep(500);

  // ————— STEP 3: Upload reference image (nếu có) —————
  if (job.referenceImage && (job.mode === 'image-to-video' || job.mode === 'image-to-image')) {
    await uploadReferenceImage(job.referenceImage);
    await sleep(1000);
  }

  // ————— STEP 4: Điền Prompt —————
  const textarea = await findElement(SELECTORS.promptInput);
  textarea.focus();
  await sleep(200);
  setReactInputValue(textarea, job.prompt);
  await sleep(500);

  // Report progress
  chrome.runtime.sendMessage({ action: 'PROGRESS_UPDATE', jobId: job.id, progress: 20 });

  // ————— STEP 5: Chọn Model —————
  await selectModel(job.model); // 'veo-3.1-fast', 'veo-3.1-quality', etc.
  await sleep(300);

  // ————— STEP 6: Chọn Aspect Ratio —————
  const ratioBtn = await waitForElement(SELECTORS.aspectRatio[job.aspectRatio], 5000);
  reactClick(ratioBtn);
  await sleep(300);

  // ————— STEP 7: Set Duration —————
  await selectDuration(job.duration);
  await sleep(300);

  chrome.runtime.sendMessage({ action: 'PROGRESS_UPDATE', jobId: job.id, progress: 30 });

  // ————— STEP 8: CLICK GENERATE! —————
  const genBtn = await findElement(SELECTORS.generateButton);
  reactClick(genBtn);

  chrome.runtime.sendMessage({ action: 'PROGRESS_UPDATE', jobId: job.id, progress: 40 });

  // ————— STEP 9: POLLING — Chờ video hoàn thành —————
  const result = await pollForCompletion(job);

  return result;
}

/**
 * Poll liên tục để check video đã render xong chưa
 * Google Flow mất 30s-5 phút tùy model
 */
async function pollForCompletion(job) {
  const startTime = Date.now();
  const MAX_WAIT = 10 * 60 * 1000; // Timeout 10 phút

  while (Date.now() - startTime < MAX_WAIT) {
    // Check lỗi
    const error = document.querySelector(SELECTORS.errorIndicator);
    if (error) throw new Error('Generation failed: ' + (error.textContent || 'Unknown error'));

    // Check progress bar
    const progressBar = document.querySelector(SELECTORS.progressBar);
    if (progressBar) {
      const value = parseInt(progressBar.getAttribute('aria-valuenow') || '0');
      chrome.runtime.sendMessage({
        action: 'PROGRESS_UPDATE', jobId: job.id,
        progress: Math.min(40 + value * 0.5, 90) // Map 0-100 → 40-90%
      });
    }

    // Check video element xuất hiện
    const video = document.querySelector(SELECTORS.videoElement);
    const complete = document.querySelector(SELECTORS.completionBadge);

    if (video || complete) {
      chrome.runtime.sendMessage({ action: 'PROGRESS_UPDATE', jobId: job.id, progress: 95 });

      // Extract video URL
      const videoUrl = await extractVideoUrl();
      const lastFrameUrl = await captureLastFrame(video);

      return {
        success: true,
        videoUrl: videoUrl,
        lastFrameUrl: lastFrameUrl // Cho auto-chaining
      };
    }

    await sleep(3000); // Poll mỗi 3 giây
  }

  throw new Error('Generation timed out after 10 minutes');
}
```

---

## VI. 🔓 MAIN WORLD INJECTION — Intercept Google Flow API

> [!WARNING]
> Content Script chạy trong **Isolated World** — KHÔNG thể đọc biến JS của page.  
> Để intercept `fetch()` calls của Google Flow → phải inject script vào **MAIN World**.

```javascript
// ══════════════════════════════════════════════
// Inject vào MAIN world từ content script
// ══════════════════════════════════════════════

function injectPageScript() {
  const script = document.createElement('script');
  script.textContent = `
    (function() {
      // ——— Override window.fetch ———
      const originalFetch = window.fetch;
      window.fetch = async function(...args) {
        const response = await originalFetch.apply(this, args);
        const url = typeof args[0] === 'string' ? args[0] : args[0]?.url;

        // Intercept video download URLs từ aisandbox-pa.googleapis.com
        if (url && url.includes('aisandbox-pa.googleapis.com')) {
          try {
            const clone = response.clone();
            const data = await clone.json();

            // Tìm video URL trong response
            if (data.downloadUrl || data.videoUri || data.mediaUrl) {
              // Gửi URL về Content Script qua CustomEvent
              window.dispatchEvent(new CustomEvent('__VEO_VIDEO_URL__', {
                detail: {
                  url: data.downloadUrl || data.videoUri || data.mediaUrl,
                  quality: data.quality || 'unknown',
                  type: data.mediaType || 'video'
                }
              }));
            }

            // Tìm generation status
            if (data.state || data.status) {
              window.dispatchEvent(new CustomEvent('__VEO_STATUS__', {
                detail: { state: data.state || data.status, progress: data.progress }
              }));
            }
          } catch(e) { /* không phải JSON, bỏ qua */ }
        }
        return response;
      };

      // ——— Override XMLHttpRequest (backup) ———
      const origOpen = XMLHttpRequest.prototype.open;
      XMLHttpRequest.prototype.open = function(method, url, ...rest) {
        this._interceptedUrl = url;
        return origOpen.apply(this, [method, url, ...rest]);
      };

      const origSend = XMLHttpRequest.prototype.send;
      XMLHttpRequest.prototype.send = function(...args) {
        this.addEventListener('load', function() {
          if (this._interceptedUrl?.includes('aisandbox-pa.googleapis.com')) {
            try {
              const data = JSON.parse(this.responseText);
              if (data.downloadUrl) {
                window.dispatchEvent(new CustomEvent('__VEO_VIDEO_URL__', {
                  detail: { url: data.downloadUrl }
                }));
              }
            } catch(e) {}
          }
        });
        return origSend.apply(this, args);
      };
    })();
  `;
  document.documentElement.appendChild(script);
  script.remove(); // Xóa tag <script> sau khi đã execute
}

// Content Script lắng nghe CustomEvent từ MAIN world
let capturedVideoUrl = null;
window.addEventListener('__VEO_VIDEO_URL__', (e) => {
  capturedVideoUrl = e.detail.url;
});

async function extractVideoUrl() {
  // Ưu tiên URL captured từ fetch interception
  if (capturedVideoUrl) {
    const url = capturedVideoUrl;
    capturedVideoUrl = null;
    return url;
  }

  // Fallback: lấy từ video element src
  const video = document.querySelector('video[src]');
  if (video?.src && !video.src.startsWith('blob:')) {
    return video.src;
  }

  // Fallback 2: tìm download button và extract href
  const dlBtn = document.querySelector('a[download], [aria-label*="Download"]');
  if (dlBtn?.href) return dlBtn.href;

  throw new Error('Could not extract video URL');
}

// Inject ngay khi content script chạy
injectPageScript();
```

