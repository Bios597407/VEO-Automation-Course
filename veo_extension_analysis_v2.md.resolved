## IV. ⚙️ SERVICE WORKER — Bộ Não Điều Phối (Chi Tiết Từng Dòng)

```javascript
// ========================================================
// background/service-worker.js
// KHÔNG CÓ DOM! Không dùng document/window.
// Đây là event-driven worker, chỉ chạy khi có event.
// ========================================================

// ——— KHỞI TẠO KHI CÀI ĐẶT EXTENSION ———
chrome.runtime.onInstalled.addListener(({ reason }) => {
  if (reason === 'install') {
    // Lần đầu cài: set default settings
    chrome.storage.local.set({
      settings: {
        maxConcurrent: 2,        // Tối đa 2 job song song
        autoDownload: true,      // Tự động tải khi xong
        downloadQuality: '1080p',// Chất lượng mặc định
        autoChaining: true,      // Tự link last frame → next prompt
        language: 'en'
      },
      queue: [],
      history: []
    });
  }
  // Kích hoạt Side Panel khi click icon
  chrome.sidePanel.setPanelBehavior({ openPanelOnActionClick: true });
});

// ——— QUEUE MANAGER CLASS ———
class QueueManager {
  constructor() {
    this.queue = [];          // Jobs chờ xử lý
    this.running = new Map(); // Jobs đang chạy: jobId → metadata
    this.completed = [];      // Jobs đã hoàn thành
    this.failed = [];         // Jobs bị lỗi
    this.maxConcurrent = 2;
    this.isPaused = false;
  }

  // Thêm hàng loạt jobs vào queue
  async addBatch(promptTexts, config) {
    const jobs = promptTexts.map((prompt, index) => ({
      id: `job_${Date.now()}_${index}`,
      prompt: prompt.trim(),
      charCount: prompt.trim().length,    // Hiển thị trên UI (như screenshot)
      mode: config.mode,                   // 'text-to-video' | 'image-to-video' | ...
      model: config.model,                 // 'veo-3.1-fast' | 'veo-3.1-quality' | ...
      aspectRatio: config.aspectRatio,     // '16:9' | '9:16' | '1:1'
      duration: config.duration,           // '5s' | '8s'
      referenceImage: null,                // Sẽ được set nếu autoChaining=true
      status: 'pending',                   // pending → running → completed/failed
      progress: 0,                         // 0-100%
      createdAt: Date.now(),
      videoUrl: null,
      thumbnailUrl: null,
      error: null
    }));

    this.queue.push(...jobs);
    await this.persistState();
    this.broadcastUpdate();
    this.processNext();
    return jobs.length;
  }

  async processNext() {
    if (this.isPaused) return;
    if (this.running.size >= this.maxConcurrent) return;
    if (this.queue.length === 0) return;

    const job = this.queue.shift();
    job.status = 'running';
    this.running.set(job.id, job);
    this.broadcastUpdate();

    try {
      // ————— BƯỚC QUAN TRỌNG: Auto-Chaining —————
      // Nếu bật autoChaining VÀ có job trước đã hoàn thành
      // → lấy last frame của video trước làm reference image cho job này
      if (this.completed.length > 0) {
        const lastCompleted = this.completed[this.completed.length - 1];
        if (lastCompleted.lastFrameUrl) {
          job.referenceImage = lastCompleted.lastFrameUrl;
        }
      }

      // Tìm tab Google Flow
      const tabs = await chrome.tabs.query({
        url: 'https://labs.google.com/fx/tools/flow/*'
      });

      if (tabs.length === 0) {
        throw new Error('Google Flow tab not found. Please open Google Flow first.');
      }

      // ————— GỬI LỆNH XUỐNG CONTENT SCRIPT —————
      const result = await chrome.tabs.sendMessage(tabs[0].id, {
        action: 'EXECUTE_AUTOMATION',
        payload: job
      });

      if (!result.success) throw new Error(result.error);

      // Cập nhật kết quả
      job.status = 'completed';
      job.progress = 100;
      job.videoUrl = result.videoUrl;
      job.lastFrameUrl = result.lastFrameUrl;
      this.completed.push(job);

      // ————— TỰ ĐỘNG TẢI VIDEO —————
      const settings = await this.getSettings();
      if (settings.autoDownload && job.videoUrl) {
        await this.downloadResult(job);
      }

    } catch (err) {
      job.status = 'failed';
      job.error = err.message;
      this.failed.push(job);
    } finally {
      this.running.delete(job.id);
      await this.persistState();
      this.broadcastUpdate();
      // ————— TIẾP TỤC JOB TIẾP THEO —————
      this.processNext();
    }
  }

  async downloadResult(job) {
    const filename = this.sanitizeFilename(job.prompt).slice(0, 50);
    await chrome.downloads.download({
      url: job.videoUrl,
      filename: `VEO_Output/${job.id}_${filename}.mp4`,
      conflictAction: 'uniquify'  // Thêm (1), (2)... nếu trùng
    });
  }

  // Broadcast trạng thái lên Side Panel UI (realtime update)
  broadcastUpdate() {
    chrome.runtime.sendMessage({
      event: 'QUEUE_UPDATE',
      data: {
        queue: this.queue,
        running: [...this.running.values()],
        completed: this.completed,
        failed: this.failed,
        stats: {
          total: this.queue.length + this.running.size + this.completed.length,
          pending: this.queue.length,
          running: this.running.size,
          done: this.completed.length,
          errors: this.failed.length
        }
      }
    });
  }

  // Lưu vào chrome.storage để survive browser restart / SW termination
  async persistState() {
    await chrome.storage.local.set({
      queue: this.queue,
      running: [...this.running.values()],
      completed: this.completed,
      failed: this.failed
    });
  }

  // Khôi phục state sau khi SW bị terminate rồi restart
  async restoreState() {
    const data = await chrome.storage.local.get(['queue','completed','failed']);
    this.queue = data.queue || [];
    this.completed = data.completed || [];
    this.failed = data.failed || [];
    // Resume processing nếu còn jobs pending
    if (this.queue.length > 0) this.processNext();
  }

  sanitizeFilename(str) {
    return str.replace(/[<>:"/\\|?*]/g, '_').replace(/\s+/g, '_');
  }

  async getSettings() {
    const { settings } = await chrome.storage.local.get('settings');
    return settings;
  }
}

const queueManager = new QueueManager();
queueManager.restoreState(); // Khôi phục khi SW khởi động

// ——— MESSAGE ROUTER: Nhận lệnh từ Side Panel & Content Script ———
chrome.runtime.onMessage.addListener((msg, sender, sendResponse) => {
  switch (msg.action) {
    case 'ADD_JOBS':
      queueManager.addBatch(msg.prompts, msg.config)
        .then(count => sendResponse({ status: 'ok', count }));
      return true; // async response

    case 'PAUSE_QUEUE':
      queueManager.isPaused = true;
      sendResponse({ paused: true });
      break;

    case 'RESUME_QUEUE':
      queueManager.isPaused = false;
      queueManager.processNext();
      sendResponse({ paused: false });
      break;

    case 'GET_STATUS':
      queueManager.broadcastUpdate();
      break;

    case 'PROGRESS_UPDATE': // Nhận từ Content Script
      const job = queueManager.running.get(msg.jobId);
      if (job) {
        job.progress = msg.progress;
        queueManager.broadcastUpdate();
      }
      break;
  }
});
```

