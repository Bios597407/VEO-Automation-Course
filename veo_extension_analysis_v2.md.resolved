## III. 📄 manifest.json — Giải Thích TỪNG DÒNG

```jsonc
{
  // ===== PHIÊN BẢN MANIFEST =====
  "manifest_version": 3,          // BẮT BUỘC dùng V3 (V2 đã bị Chrome deprecate)
                                   // V3 thay background page → service worker
                                   // V3 không cho load remote code từ CDN

  // ===== THÔNG TIN CƠ BẢN =====
  "name": "__MSG_extensionName__", // Dùng i18n key → hiển thị tên theo ngôn ngữ browser
  "version": "2.3.6",             // SemVer: Major.Minor.Patch
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",         // Ngôn ngữ mặc định nếu browser không match

  // ===== PERMISSIONS (Quyền truy cập) =====
  "permissions": [
    "sidePanel",    // Mở Side Panel UI persistent bên cạnh webpage
    "storage",      // chrome.storage.local — lưu queue, settings (KHÔNG phải cookies!)
    "downloads",    // chrome.downloads.download() — tải video/ảnh tự động
    "scripting",    // chrome.scripting.executeScript() — inject script động vào tab
    "tabs",         // chrome.tabs.query/sendMessage — tìm tab và gửi lệnh
    "activeTab"     // Truy cập tab đang active khi user click extension icon
  ],

  // ===== HOST PERMISSIONS (Website được phép thao tác) =====
  "host_permissions": [
    "https://labs.google.com/fx/tools/flow/*",      // Google Flow UI
    "https://aisandbox-pa.googleapis.com/*"          // Google Flow backend API
    // ↑ Extension CHỈ chạy trên 2 domain này = bảo mật tốt
  ],

  // ===== BACKGROUND SERVICE WORKER =====
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"    // Cho phép dùng ES import/export
    // QUAN TRỌNG: Service Worker KHÔNG có DOM!
    // Không thể dùng document.querySelector() ở đây
    // Nó là "bộ não" điều phối, không phải "tay chân"
  },

  // ===== CONTENT SCRIPTS (Inject tự động vào webpage) =====
  "content_scripts": [{
    "matches": ["https://labs.google.com/fx/tools/flow/*"],
    "js": [
      "content-scripts/flow-automator.js"
      // File này chạy TRONG context của Google Flow
      // Nó có thể document.querySelector() trên Google Flow DOM
    ],
    "run_at": "document_idle"
    // document_idle = chạy SAU KHI DOM đã load xong
    // Alternatives: document_start (trước DOM), document_end (sau DOM, trước resources)
  }],

  // ===== SIDE PANEL =====
  "side_panel": {
    "default_path": "side-panel/panel.html"
    // HTML file hiển thị trong Chrome Side Panel
    // Panel này PERSISTENT — không bị đóng khi switch tab!
  },

  // ===== EXTENSION ICON =====
  "action": {
    "default_icon": "icons/icon-32.png",  // Icon trên toolbar Chrome
    "default_title": "VEO Automation"     // Tooltip khi hover
  },

  "icons": {
    "16": "icons/icon-16.png",    // Favicon
    "48": "icons/icon-48.png",    // Extension management page
    "128": "icons/icon-128.png"   // Chrome Web Store listing (con hamster)
  }
}
```

